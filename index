<!DOCTYPE html>
<html>
<head>
  <title>Protected Site</title>
  <style>
    body {
      background: black;
      color: #00ffcc;
      font-family: monospace;
      text-align: center;
      margin-top: 120px;
    }
    input {
      padding: 10px;
      font-size: 16px;
      background: #111;
      color: #00ffcc;
      border: 1px solid #00ffcc;
    }
    button {
      padding: 10px;
      font-size: 16px;
      cursor: pointer;
      background: #00ffcc;
      border: none;
      color: black;
    }
  </style>
</head>
<body>

  <h1>ACCESS REQUIRED</h1>
  <input type="password" id="passwordBox" placeholder="Enter password">
  <br><br>
  <button onclick="checkPassword()">ENTER</button>

  <script>
    function checkPassword() {
      var password = document.getElementById("passwordBox").value;

      if (password === "ResinSword") {
        window.location.href = "home.html";
      } else {
        alert("ACCESS DENIED");
      }
    }
  </script>

</body>
</html>
